		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	partition 'Opportunity Calendar-e59f2a98-a17b-43c5-9430-3661e3b638f8' = calculated
		mode: import
		source = ```
				
				VAR StartDate =
				    DATE ( YEAR ( MIN ( Opportunities[Close date] ) )-1, 1, 1 )
				VAR EndDate =
				    DATE ( YEAR (
				        IF (
				            ISBLANK ( MAX ( Opportunities[Close date] ) ),
				            TODAY (),
				            MAX ( Opportunities[Close date] )
				        ) + 1
				    ), 12, 31 )
				VAR BASECALENDAR =
				    CALENDAR ( StartDate, EndDate )
				
				VAR FiscalCalendarFirstMonth = 10 
				VAR OffsetFiscalYear = IF ( FiscalCalendarFirstMonth > 1, 1, 0 )
				VAR TypeStartFiscalYear = 1 -- Fiscal year as Calendar Year of : 0 - First day of fiscal year, 1 - Last day of fiscal year
				
				
				RETURN
				    GENERATE (
				        BASECALENDAR,
				        VAR DateSequence = DATEDIFF ( StartDate, [DATE], DAY ) + 1
				        VAR BASEDATE = [DATE]
				        VAR YEARDATE = YEAR ( BASEDATE )
				        VAR MONTHNUMBER = MONTH ( BASEDATE )
				        VAR MONTHNAME = FORMAT ( BASEDATE, "MMMM" )
				        VAR YEARMONTHNAME = FORMAT ( BASEDATE, "MMM YYYY" )
				        VAR YEARMONTHNUMBER = YEARDATE * 12 + ( MONTHNUMBER - 1 )
				        VAR YEARWEEK = YEARDATE & "-W" & RIGHT ( "0" & WEEKNUM ( BASEDATE ), 2 )
				        VAR DayNumberOfWeek = WEEKDAY ( [Date] )
				        VAR StartOfWeek = [Date] - ( 1 * DayNumberOfWeek )
				        VAR StartOfRelativeWeek = [Date] - WEEKDAY ( [Date] ) + 1
				        VAR StartOfCurrentWeek = TODAY () - WEEKDAY ( TODAY () ) + 1
				        VAR RelativeYear = DATEDIFF(TODAY(),[Date],YEAR)
				        VAR RelativeMonth = DATEDIFF(TODAY(),[Date],MONTH)
				        VAR RelativeWeek = ( StartOfRelativeWeek - StartOfCurrentWeek ) / 7
				        VAR RelativeDay = BASEDATE - TODAY()
				        VAR Relative7DayPeriod = ROUNDDOWN(([Date] - TODAY())/7,0) + IF([Date]<TODAY(),+1,+2)
				        VAR Relative30DayPeriod = ROUNDDOWN(([Date] - TODAY())/30,0) + IF([Date]>TODAY(),1,0)   
				        VAR Relative365DayPeriod = ROUNDDOWN(([Date] - TODAY())/365,0) + IF([Date]>TODAY(),1,0)   
				        VAR FiscalYearNumber = IF.EAGER(MONTHNUMBER >= FiscalCalendarFirstMonth, YEARDATE + (OffsetFiscalYear * TypeStartFiscalYear), YEARDATE )
				        VAR QuarterNumber = QUARTER(DATE(YEARDATE, MOD(MONTH(BASEDATE)-FiscalCalendarFirstMonth,12)+1,1))
				        VAR FiscalYearQuarter = "FY-"&RIGHT(FiscalYearNumber,2) & " Q" & QuarterNumber
				
				        
				
				        RETURN
				            ROW (
				                "DaySeq", DateSequence,
				                "Year", YEARDATE,
				                "Month #", MONTHNUMBER,
				                "MonthSort", LEFT(MONTHNAME,3),
				                "Month", MONTHNAME,
				                "Year Month #", YEARMONTHNUMBER,
				                "Year Month", YEARMONTHNAME,
				                "Year Week", YEARWEEK,
				                "Week", StartOfWeek,
				                "Relative Year", RelativeYear,
				                "Relative Month", RelativeMonth,
				                "Relative Week", RelativeWeek,
				                "Relative Day", RelativeDay,
				                "Relative 7 Day Period", Relative7DayPeriod,
				                "Relative 30 Day Period", Relative30DayPeriod,
				                "Relative 365 Day Period", Relative365DayPeriod,
				                "Fiscal Year", "FY-" & RIGHT(FiscalYearNumber,2),
				                "Fiscal Quarter", "Q" & QuarterNumber,
				                "Fiscal Year Quarter", FiscalYearQuarter
				                )
				            )
				```

